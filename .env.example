# ========================================
# LIMS 系统环境变量配置示例
# 使用时请复制为 .env 文件并修改配置
# ========================================

# 服务端口配置
SERVER_PORT=8080
WEB_PORT=80

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# ========================================
# MySQL 数据库配置（使用外部MySQL）
# ========================================
SPRING_DATASOURCE_URL=jdbc:mysql://192.168.1.100:3306/lims?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# ========================================
# Redis 缓存配置（使用外部Redis）
# ========================================
SPRING_DATA_REDIS_HOST=192.168.1.100
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=your_redis_password
SPRING_DATA_REDIS_DATABASE=0

# ========================================
# JWT 配置
# ========================================
JWT_SECRET=lims-secret-key-2024-environment-detection-labs-change-me
JWT_EXPIRATION=86400000

# ========================================
# MinIO 对象存储配置（使用外部MinIO）
# ========================================
MINIO_ENDPOINT=http://192.168.1.100:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_password
MINIO_BUCKET_NAME=lims
